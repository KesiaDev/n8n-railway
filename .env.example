# N8N Railway — Variáveis de Ambiente
# Configure estas variáveis no painel do Railway

# Banco de dados PostgreSQL (Railway)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=seu-host.railway.internal
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=railway
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=sua-senha

# N8N Config
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://seu-n8n.up.railway.app/

# Segurança
N8N_ENCRYPTION_KEY=chave-aleatoria-32-chars
N8N_USER_MANAGEMENT_JWT_SECRET=outra-chave-aleatoria

# Fuso horário
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# API pública habilitada (para o agente Nina acessar)
N8N_PUBLIC_API_DISABLED=false
